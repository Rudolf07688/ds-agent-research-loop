# Google Vertex AI / Gemini configuration.
# Copy this file to `.env` only if you need to override the defaults below.
# `.env` is gitignored and MUST NOT be committed.
#
# AUTHENTICATION: this project uses Application Default Credentials (ADC) — NOT an API
# key. Authenticate once locally with:
#     gcloud auth application-default login
# In a container, mount the ADC file and point GOOGLE_APPLICATION_CREDENTIALS at it.
# Never put credentials in this file or commit them.

# Force the google.genai backend into Vertex AI mode (default TRUE).
# GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Target Google Cloud project (default: research-se-gen-ai).
# GOOGLE_CLOUD_PROJECT=research-se-gen-ai

# Vertex AI location/region (default: global).
# GOOGLE_CLOUD_LOCATION=global

# Gemini model for both the seed-generation and next-step calls (default: gemini-3.5-flash).
# GEMINI_MODEL=gemini-3.5-flash

# Optional run-parameter overrides (CLI flags take precedence over these).
# N_ITERATIONS=30
# PATIENCE=3
# TARGET_SIZE=500
# PRIMARY_METRIC=rmse

# --- Memory-compaction ablation (feature 003) ---------------------------------
# Postgres connection for durable cell/record/memory/artifact/log state (Principle IV).
# A bare postgresql:// URL is accepted; the app normalizes it to the psycopg driver.
# DATABASE_URL=postgresql+psycopg://autods:autods@localhost:5432/autods
#
# Benchmark version stamped onto every cell (Principle IX).
# BENCHMARK_VERSION=v1
#
# Sweep factors. DATASETS empty = the full suite. Lists are comma-separated.
# DATASETS=delivery_time,diabetes,breast_cancer
# REGIMES=recent_only,all_raw,compacted_recent
# SEEDS=0,1,2,3,4
#
# Recent-window k and compaction cadence m (Decision 10 defaults).
# RECENT_K=5
# COMPACTION_M=10
#
# Optional FR-024 token-threshold compaction trigger (off by default).
# COMPACTION_TOKEN_THRESHOLD=8000
