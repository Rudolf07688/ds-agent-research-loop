# LLM provider credentials and model selection.
# Copy this file to `.env` and fill in your values. `.env` is gitignored and
# MUST NOT be committed.

# API key for an OpenAI-compatible provider that supports JSON-schema structured output.
LLM_API_KEY=sk-your-key-here

# Model name to use for both the seed-generation and next-step calls.
LLM_MODEL=gpt-4o-mini

# Optional: override the API base URL for an OpenAI-compatible endpoint.
# LLM_BASE_URL=https://api.openai.com/v1

# Optional run-parameter overrides (CLI flags take precedence over these).
# N_ITERATIONS=10
# PATIENCE=3
# TARGET_SIZE=500
# PRIMARY_METRIC=rmse
